{
    "name": "@iamlittleboring/tg-webapp-tools",
    "version": "1.0.2",
    "description": "React utilities and components for Telegram Web Apps",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "@twa-dev/sdk": "^8.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@twa-dev/types": "^8.0.2",
        "typescript": "^5.0.0"
    },
    "keywords": [
        "telegram",
        "telegram-webapp",
        "telegram-web-app",
        "twa",
        "react",
        "typescript",
        "webapp",
        "sdk"
    ],
    "author": "iamlittleboring",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iamlittleboring/tg-webapp-tools.git"
    },
    "homepage": "https://github.com/iamlittleboring/tg-webapp-tools#readme",
    "bugs": {
        "url": "https://github.com/iamlittleboring/tg-webapp-tools/issues"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    }
}