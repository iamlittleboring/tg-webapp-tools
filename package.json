{
    "name": "tg-webapp-tools",
    "version": "1.0.0",
    "description": "A React component library written in TypeScript",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "@twa-dev/sdk": "^8.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "typescript": "^5.0.0"
    },
    "keywords": [
        "react",
        "typescript",
        "components",
        "library"
    ],
    "author": "reshetivskyy",
    "license": "MIT",
    "dependencies": {
        "@twa-dev/types": "^8.0.2"
    }
}
