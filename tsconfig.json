{
    "compilerOptions": {
        "target": "ES2018",
        "module": "ESNext",
        "declaration": true,
        "declarationDir": "./dist",
        "emitDeclarationOnly": false,
        "outDir": "./dist",
        "moduleResolution": "Node",
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["DOM", "ES2018"]
    },
    "include": ["src"]
}
